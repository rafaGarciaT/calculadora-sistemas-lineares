    "    }\n",
    "   },\n",
    "   \"source\": [\n",
    "    \"import numpy as np\\n\",\n",
    "    \"from src.solver import resolver\\n\",\n",
    "    \"from src.escalonamento import escalonar_sistema\\n\",\n",
    "    \"from src.input_output import imprimir_sistema, imprimir_resultado\"\n",
    "   ],\n",
    "   \"outputs\": [],\n",
    "   \"execution_count\": 4\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {},\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"source\": [\n",
    "    \"# 3. Exemplos\\n\",\n",
    "    \"\\n\",\n",
    "    \"A seguir estão algumas demonstrações do nosso código resolvendo sistemas lineares.\\n\",\n",
    "    \"\\n\",\n",
    "    \"O código em si funciona a partir do seguinte fluxo, presente em main.py.\\n\",\n",
    "    \"\\n\",\n",
    "    \"```python\\n\",\n",
    "    \"tamanho_sistema = solicitar_tamanho_de_sistema()\\n\",\n",
    "    \"sistema = solicitar_sistema(tamanho_sistema)\\n\",\n",
    "    \"imprimir_sistema(sistema)\\n\",\n",
    "    \"\\n\",\n",
    "    \"sistema_escalonado = escalonar_sistema(sistema)\\n\",\n",
    "    \"imprimir_sistema(sistema_escalonado)\\n\",\n",
    "    \"\\n\",\n",
    "    \"resultado = resolver(sistema_escalonado)\\n\",\n",
    "    \"imprimir_resultado(resultado)\\n\",\n",
    "    \"```\\n\",\n",
    "    \"\\n\",\n",
    "    \"No projeto, utilizamos ndarrays para representar os sistemas lineares como matrizes aumentadas. Elas são escalonadas e resolvidas usando as funções que implementamos.\\n\",\n",
    "    \"\\n\",\n",
    "    \"Vamos ver como isso funciona na prática com alguns exemplos demonstrativos.\\n\",\n",
    "    \"\\n\",\n",
    "    \"## 3.1 Exemplo SPD\\n\",\n",
    "    \"\\n\",\n",
    "    \"Sistema original:\\n\",\n",
    "    \"\\n\",\n",
    "    \"$$\\n\",\n",
    "    \"\\\\huge\\n\",\n",
    "    \"\\\\begin{cases}\\n\",\n",
    "    \"x + y + z = 6 \\\\\\\\\\n\",\n",
    "    \"2x - y + z = 3 \\\\\\\\\\n\",\n",
    "    \"x + 2y - z = 3\\n\",\n",
    "    \"\\\\end{cases}\\n\",\n",
    "    \"$$\\n\",\n",
    "    \"\\n\",\n",
    "    \"Representação matricial usando ndarrays:\\n\",\n",
    "    \"\\n\",\n",
    "    \"$$\\n\",\n",
    "    \"\\\\large\\n\",\n",
    "    \"\\\\begin{pmatrix} 1 & 1 & 1 \\\\\\\\ 2 & -1 & 1 \\\\\\\\ 1 & 2 & -1 \\\\end{pmatrix}\\n\",\n",
    "    \"\\\\begin{pmatrix} x \\\\\\\\ y \\\\\\\\ z \\\\end{pmatrix}\\n\",\n",
    "    \"=\\n\",\n",
    "    \"\\\\begin{pmatrix} 6 \\\\\\\\ 3 \\\\\\\\ 3 \\\\end{pmatrix}\\n\",\n",
    "    \"\\\\rightarrow\\n\",\n",
    "    \"\\\\begin{pmatrix}\\n\",\n",
    "    \"1 & 1 & 1 & 6 \\\\\\\\\\n\",\n",
    "    \"2 & -1 & 1 & 3 \\\\\\\\\\n\",\n",
    "    \"1 & 2 & -1 & 3\\n\",\n",
    "    \"\\\\end{pmatrix}\\n\",\n",
    "    \"$$\\n\"\n",
    "   ],\n",
    "   \"id\": \"8df492b7bc132975\"\n",
    "  },\n",
    "  {\n",
    "   \"metadata\": {\n",
    "    \"ExecuteTime\": {\n",
    "     \"end_time\": \"2026-03-26T13:36:59.652486Z\",\n",
    "     \"start_time\": \"2026-03-26T13:36:59.647260Z\"\n",
    "    }\n",
    "   },\n",
    "   \"cell_type\": \"code\",\n",
    "   \"source\": [\n",
    "    \"spd_sistema = np.array([[1, 1, 1, 6], [2, -1, 1, 3], [1, 2, -1, 3]], dtype=int)\\n\",\n",
    "    \"print(f\\\"Sistema original:\\\")\\n\",\n",
    "    \"imprimir_sistema(spd_sistema)\"\n",
    "   ],\n",
